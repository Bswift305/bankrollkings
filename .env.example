# Bankroll Kings local environment template
# Copy to `.env.local` and fill in real values for your machine.

# Odds / data providers
ODDS_API_KEY=
CFBD_API_KEY=

# Flask/session security
# Generate locally with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Stripe checkout — single All Access plan ($19.99/mo, monthly only).
# STRIPE_ALL_ACCESS_MONTHLY_URL: payment link for the standard $19.99/mo price.
# STRIPE_ALL_ACCESS_FOUNDER_MONTHLY_URL: payment link for the same price with the
#   founders coupon attached ($9.99 off for 12 months => $10/mo for year one).
#   Set max_redemptions=100 on the coupon in Stripe as the hard backstop.
STRIPE_ALL_ACCESS_MONTHLY_URL=
STRIPE_ALL_ACCESS_FOUNDER_MONTHLY_URL=
STRIPE_BILLING_PORTAL_URL=
STRIPE_BILLING_PORTAL_CONFIG_ID=
