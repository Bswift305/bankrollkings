# Local secrets
.env
.env.*
!.env.example

# Local-only attic: stray exports/docs/logs/archives moved out of the repo root
# to keep production code uncluttered. Never deployed; safe to delete locally.
/_attic/

# SSH / private keys — never commit
*.pem
*.key
*.ppk
id_ed25519
id_rsa

# Stripe / API secret-bearing files — never commit (e.g. sk_live_*.txt)
sk_live_*
sk_test_*
*secret*.txt

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Runtime logs and server output
logs/
.runtime/
*.log
server*.out.txt
server*.err.txt

# Local assistant/editor state
.claude/

# Generated app data and bulky local datasets
data/cache/
data/debug/
data/gamelogs/
data/historical/
data/injuries/
data/odds/
data/props/
data/rosters/
data/schedules/
data/tracking/

# Local exports, spreadsheets, docs, archives
*.zip
*.xlsx
*.xls
*.docx
*.pptx
*.csv
*.lnk

# Raw local asset dumps; app-ready assets live under static/
# Leading slash anchors this to the repo root ONLY — without it, a
# case-insensitive (Windows/macOS) filesystem also matches static/logos/
# and silently drops the sidebar league logos from the repo.
/Logos/

# Keep intentional repo seed/config CSVs, not generated slate context
!data/context/MLB_BallparkFactors.csv
data/context/MLB_GameContext.csv

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
