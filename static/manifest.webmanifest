{
  "name": "Bankroll Kings",
  "short_name": "Bankroll",
  "description": "Sports betting intelligence, prop context, and ticket tracking.",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "background_color": "#05070a",
  "theme_color": "#0b1418",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/static/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/static/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/static/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/static/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "NBA Props",
      "short_name": "NBA",
      "url": "/sports/nba/props",
      "description": "Open the NBA prop board."
    },
    {
      "name": "MLB Props",
      "short_name": "MLB",
      "url": "/sports/mlb/props",
      "description": "Open the MLB prop board."
    },
    {
      "name": "Review Center",
      "short_name": "Review",
      "url": "/candidate-review",
      "description": "Open result review and player profile analysis."
    }
  ]
}
