# Force LF on files that run on the Linux server. CRLF can break systemd
# units, shell scripts, and Nginx configs when checked out on the host.
*.sh            text eol=lf
*.service       text eol=lf
*.conf          text eol=lf
deploy/*        text eol=lf
gunicorn.conf.py text eol=lf
wsgi.py         text eol=lf
*.py            text eol=lf
